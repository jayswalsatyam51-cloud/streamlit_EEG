# Copy to .env and fill in values. Never commit .env.

# Google Gemini (Streamlit AI analysis)
GEMINI_API_KEY=
# Optional:
# GEMINI_MODEL=gemini-2.5-flash

# DigitalOcean Spaces (optional — if unset, Render serves downloads from /api/jobs/…)
DO_REGION=
DO_ACCESS_KEY=
DO_ACCESS_SECRET=
DO_BUCKET_NAME=

# Render: set to your service URL, e.g. https://eeg-cswl.onrender.com
PUBLIC_BASE_URL=

# Comma-separated origins for CORS (default *)
# CORS_ORIGINS=*
